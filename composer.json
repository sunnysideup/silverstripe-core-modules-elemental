{
  "name": "sunnysideup/core-modules-elemental",
  "type": "silverstripe-recipe",
  "description": "Core modules for Silverstripe CMS for Elemental",
  "require": {
    "dnadesign/silverstripe-elemental": "^5",
    "dnadesign/silverstripe-elemental-userforms": "^4",
    "dnadesign/silverstripe-elemental-virtual": "^2",
    "sunnysideup/core-modules": "5.x-dev",
    "sunnysideup/silverstripe-elemental-modeladmin": "5.x-dev",
    "sunnysideup/elemental-edit-me-button": "5.x-dev",
    "sunnysideup/elemental-switch-tabs": "5.x-dev",
    "sunnysideup/elemental-template": "5.x-dev",
    "sunnysideup/preview-all-elements": "5.x-dev",
    "maxime-rainville/anyfield": "^0.0"
  },
  "require-dev": {},
  "suggest": {
    "sunnysideup/core-modules": "dev-master"
  },
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "Nicolaas Francken",
      "email": "modules@sunnysideup.co.nz",
      "role": "lead developer"
    }
  ],
  "prefer-stable": true,
  "minimum-stability": "dev",
  "prefer": "source",
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "silverstripe/recipe-plugin": true,
      "silverstripe/vendor-plugin": true
    }
  }
}
